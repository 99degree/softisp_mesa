#version 460
layout(local_size_x = 256) in;
layout(set = 0, binding = 0, std430) buffer OutBuf { float data[]; };
void main() {
    uint idx = gl_GlobalInvocationID.x;
    float v = float(idx) * 1.0001f;
    for (int i = 0; i < 1024; i++) {
        v = sin(v) * 1.000001f + cos(v * 0.999999f);
        v = sqrt(abs(v) + 0.01f) + v * 0.9999f;
        v = v * 0.5f + 0.5f * (v - 1.0f) * (v + 1.0f);
    }
    data[idx] = v;
}
